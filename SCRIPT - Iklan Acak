<!-- CSS JIAARA IKLAN JEJER -->
<style>
  .jiaara-iklan-jejer-wrapper {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 10px;
    /* Penambahan Max Width 85% dan Center Alignment */
    max-width: 85%;
    margin: 20px auto; 
    font-family: Arial, sans-serif;
  }

  .jiaara-iklan-jejer-card {
    border: 1px solid #d4a373; 
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: #333;
    background: #fff;
    transition: transform 0.2s;
  }

  .jiaara-iklan-jejer-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
  }

  .jiaara-iklan-jejer-img-box {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f0f8ff;
  }

  .jiaara-iklan-jejer-img-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .jiaara-iklan-jejer-info {
    border-top: 1px solid #d4a373;
    padding: 8px 5px;
    text-align: center;
    font-size: 11px;
    line-height: 1.2;
    font-weight: bold;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-transform: capitalize;
  }

  /* Responsive: Jika di HP, lebar tetap 85% tapi kolom jadi 2 */
  @media (max-width: 768px) {
    .jiaara-iklan-jejer-wrapper {
      grid-template-columns: repeat(2, 1fr);
      max-width: 90%; /* Sedikit lebih lebar di HP agar tidak terlalu sempit */
    }
  }
</style>

<!-- CONTAINER UNTUK PRODUK -->
<div id="jiaara-iklan-jejer-container" class="jiaara-iklan-jejer-wrapper">
  <!-- Konten diisi otomatis oleh JS -->
</div>

<!-- JAVASCRIPT JIAARA IKLAN JEJER -->
<script>
  (function() {
    // DATA PRODUK: Tambahkan hingga 50 produk di sini
    const jiaara_iklan_jejer_dataPool = [
      { nama: "Produk 1: Kipas Portable", link: "#link1", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 2: Powerbank", link: "#link2", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 3: Headset", link: "#link3", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 4: Mouse Gaming", link: "#link4", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 5: Keyboard", link: "#link5", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 6: Smartwatch", link: "#link6", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" },
      { nama: "Produk 7: Lampu Tidur", link: "#link7", img: "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgfU5qZ5N_l-Zl7m3-GZtV0vR3t_H3vM_D/s1600/placeholder.png" }
      // ... teruskan hingga 50 data
    ];

    function jiaara_iklan_jejer_shuffle(array) {
      for (let i = array.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [array[i], array[j]] = [array[j], array[i]];
      }
      return array;
    }

    function jiaara_iklan_jejer_render() {
      const container = document.getElementById('jiaara-iklan-jejer-container');
      if (!container) return;

      const shuffledData = jiaara_iklan_jejer_shuffle([...jiaara_iklan_jejer_dataPool]);
      const selected = shuffledData.slice(0, 5);

      let html = '';
      selected.forEach(p => {
        html += `
          <a href="${p.link}" class="jiaara-iklan-jejer-card">
            <div class="jiaara-iklan-jejer-img-box">
              <img src="${p.img}" alt="${p.nama}" loading="lazy">
            </div>
            <div class="jiaara-iklan-jejer-info">${p.nama}</div>
          </a>`;
      });
      container.innerHTML = html;
    }

    // Inisialisasi
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', jiaara_iklan_jejer_render);
    } else {
      jiaara_iklan_jejer_render();
    }
  })();
</script>
